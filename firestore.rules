rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ADMIN ALLOWLIST =====
    // Only these emails can perform admin actions
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'kanthan180@gmail.com' ||
        request.auth.token.email == 'suryayogeshkumar301@gmail.com' ||
        request.auth.token.email == 'cursordrew@gmail.com'
      );
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // ===== REVIEWS COLLECTION =====
    match /reviews/{reviewId} {

      // Anyone can READ approved reviews (for the public website)
      // But only admins can read ALL reviews (including pending/rejected/spam)
      allow read: if true;

      // Anyone can CREATE a review (public submission)
      // But force status to 'pending' on creation — cannot self-approve
      allow create: if request.resource.data.status == 'pending'
                    && request.resource.data.keys().hasAll(['name', 'rating', 'text', 'status', 'timestamp']);

      // Only admins can UPDATE reviews (approve, reject, spam, feature)
      allow update: if isAdmin();

      // Only admins can DELETE reviews
      allow delete: if isAdmin();
    }

    // ===== LEADS COLLECTION (contact form) =====
    match /leads/{leadId} {
      // Anyone can create a lead (public contact form)
      allow create: if true;

      // Only admins can read, update, delete leads
      allow read, update, delete: if isAdmin();
    }

    // ===== DENY ALL OTHER COLLECTIONS =====
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
